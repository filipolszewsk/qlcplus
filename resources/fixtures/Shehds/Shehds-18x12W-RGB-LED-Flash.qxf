 <Channel Name="Blue Zone 7" Preset="IntensityBlue"/>
 <Channel Name="Red Zone 8" Preset="IntensityRed"/>
 <Channel Name="Green Zone 8" Preset="IntensityGreen"/>
 <Channel Name="Blue Zone 8" Preset="IntensityBlue"/>
