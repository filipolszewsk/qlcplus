<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE FixtureDefinition>
<FixtureDefinition xmlns="http://www.qlcplus.org/FixtureDefinition">
 <Creator>
  <Name>Q Light Controller Plus</Name>
  <Version>4.14.2 GIT</Version>
  <Author>filipolszewski</Author>
 </Creator>
 <Manufacturer>Shehds</Manufacturer>
 <Model>18x12W RGB LED Flash</Model>
 <Type>LED Bar (Beams)</Type>
 <Channel Name="Red" Preset="IntensityRed"/>
 <Channel Name="Green" Preset="IntensityGreen"/>
 <Channel Name="Blue" Preset="IntensityBlue"/>
 <Channel Name="Total Dimmer" Preset="IntensityMasterDimmer"/>
 <Channel Name="Strobe">
  <Group Byte="0">Shutter</Group>
  <Capability Min="0" Max="0" Preset="ShutterOpen">No function</Capability>
  <Capability Min="1" Max="255" Preset="StrobeSlowToFast">Strobe slow to fast (0-38Hz)</Capability>
 </Channel>
 <Channel Name="Macro Mode">
  <Group Byte="0">Effect</Group>
  <Capability Min="0" Max="0">No function</Capability>
  <Capability Min="1" Max="127">Auto program 1-127</Capability>
  <Capability Min="128" Max="255">Extended effects</Capability>
 </Channel>
 <Channel Name="Macro Speed">
  <Group Byte="0">Speed</Group>
  <Capability Min="0" Max="0">No function</Capability>
  <Capability Min="1" Max="255" Preset="SpeedGlobalSlowToFast">Macro speed slow to fast</Capability>
 </Channel>
 <Channel Name="Background Color">
  <Group Byte="0">Colour</Group>
  <Capability Min="0" Max="0">No function</Capability>
  <Capability Min="1" Max="250">Background color selection</Capability>
 </Channel>
 <Channel Name="Background Dimming">
  <Group Byte="0">Intensity</Group>
  <Capability Min="0" Max="0">No function</Capability>
  <Capability Min="1" Max="250">Background dimming dark to bright</Capability>
 </Channel>
 <Channel Name="Red Zone 1" Preset="IntensityRed"/>
 <Channel Name="Green Zone 1" Preset="IntensityGreen"/>
 <Channel Name="Blue Zone 1" Preset="IntensityBlue"/>
