  <Capability Min="116" Max="128">Auto Color 3</Capability>
  <Capability Min="129" Max="141">Auto Color 4</Capability>
  <Capability Min="142" Max="154">Auto Color 5</Capability>
  <Capability Min="155" Max="167">Auto Color 6</Capability>
  <Capability Min="168" Max="180">Auto Color 7</Capability>
