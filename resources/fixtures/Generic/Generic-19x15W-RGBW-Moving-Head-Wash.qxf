  <Capability Min="233" Max="249">Auto Color 12</Capability>
  <Capability Min="250" Max="255">Sound Color</Capability>
 </Channel>
 <Channel Name="ColorAuto Speed">
  <Group Byte="0">Speed</Group>
  <Capability Min="0" Max="255" Preset="SpeedGlobalSlowToFast">Color auto speed slow to fast</Capability>
 </Channel>
 <Channel Name="Pan Fine" Preset="PositionPanFine"/>
 <Channel Name="Tilt Fine" Preset="PositionTiltFine"/>
 <Channel Name="Restoration">
  <Group Byte="0">Maintenance</Group>
  <Capability Min="0" Max="249">Auto effect</Capability>
  <Capability Min="250" Max="255" Preset="ResetAll">Restoration</Capability>
 </Channel>
 <Channel Name="CTO">
  <Group Byte="0">Colour</Group>
  <Capability Min="0" Max="249">No CTO</Capability>
  <Capability Min="250" Max="255" Preset="ColorTemperature">Color temperature 2000K-8000K</Capability>
 </Channel>
