 <Channel Name="Green Zone 3" Preset="IntensityGreen"/>
 <Channel Name="Blue Zone 3" Preset="IntensityBlue"/>
 <Channel Name="White Zone 3" Preset="IntensityWhite"/>
 <Channel Name="Strobe">
  <Group Byte="0">Shutter</Group>
  <Capability Min="0" Max="9" Preset="ShutterOpen">No strobe</Capability>
  <Capability Min="10" Max="255" Preset="StrobeSlowToFast">Strobe slow to fast</Capability>
 </Channel>
 <Channel Name="Zoom" Preset="BeamZoomSmallBig"/>
 <Channel Name="Macro">
  <Group Byte="0">Effect</Group>
  <Capability Min="0" Max="9">No effect</Capability>
  <Capability Min="10" Max="19">Color 1</Capability>
  <Capability Min="20" Max="29">Color 2</Capability>
  <Capability Min="30" Max="39">Color 3</Capability>
  <Capability Min="40" Max="49">Color 4</Capability>
